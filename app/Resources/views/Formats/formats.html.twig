{% extends '/layout.html.twig' %}

{% block title %}Play Format{% endblock %}

{% block body %}
<div class="container">

  <h1>{{ block('title') }}</h1>

  <div id="list">

    <div class="row">
      <div class="col-sm-12">
        <h2>SoCal Eternal</h2>
        <p class="lead">SanSan South plays a single format: <strong>SoCal Eternal</strong>.</p>
        <p>SoCal Eternal takes the full <strong>Eternal</strong> card pool &mdash; every card ever printed for Android: Netrunner, across every cycle and set &mdash; and bans the strongest ~25% of it. Everything else is legal.</p>
        <p>The goal is a wide-open card pool where the usual &ldquo;best&rdquo; answers are off the table, pushing decks toward less-travelled lines and more interesting building decisions.</p>
      </div>
    </div>

    <div class="row">
      <div class="col-sm-4">
        <h2>SoCal Eternal Format</h2>

        <h4>Current Ban List</h4>
        {% if activeMwl %}
          <p>
            <strong><a href="{{ path('banlists') }}">{{ activeMwl.name }}</a></strong><br />
            active as of <strong>{{ activeMwl.dateStart|date('Y-m-d') }}</strong><br />
            <a href="{{ path('banlists') }}">{{ bannedCount }} cards banned</a>
          </p>
        {% else %}
          <p><strong>None</strong></p>
        {% endif %}

        <h4>Corp Decklists</h4>
        <ul>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'corp'}) }}">Any Corp</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'haas-bioroid'}) }}"><span class="icon icon-haas-bioroid influence-haas-bioroid"></span> Haas-Bioroid</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'jinteki'}) }}"><span class="icon icon-jinteki influence-jinteki"></span> Jinteki</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'nbn'}) }}"><span class="icon icon-nbn influence-nbn"></span> NBN</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'weyland-consortium'}) }}"><span class="icon icon-weyland-consortium influence-weyland-consortium"></span> Weyland Consortium</a></li>
        </ul>

        <h4>Runner Decklists</h4>
        <ul>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'runner'}) }}">Any Runner</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'anarch'}) }}"><span class="icon icon-anarch influence-anarch"></span> Anarch</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'criminal'}) }}"><span class="icon icon-criminal influence-criminal"></span> Criminal</a></li>
          <li><a href="{{ path('decklists_list', {type:'find', 'faction':'shaper'}) }}"><span class="icon icon-shaper influence-shaper"></span> Shaper</a></li>
        </ul>

        <h4>Card Pool</h4>
        <p>Every released card is part of the Eternal pool. Browse the full pool by <a href="{{ path('cards_sets') }}">set</a>, or build a deck to see live legality against the SoCal Ban List.</p>
      </div>
    </div>

  </div>
</div>
{% endblock %}
