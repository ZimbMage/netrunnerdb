{% extends '/layout.html.twig' %}

{% block title %}Ban List{% endblock %}

{% block body %}
<div class="container" id="banlists">
  <h1>{{ block('title') }}</h1>
  <div>
    <p>SanSan South plays one <a href="{{ path('formats') }}">format</a>: <strong>SoCal Eternal</strong> &mdash; the full Eternal card pool with the strongest ~25% of cards banned. This page lists every banned card.</p>
    <h2>Explanation</h2>
    <ul>
      <li><b>Banned:</b> You cannot include any copies of a banned card in your deck. Everything not on this list is legal.</li>
    </ul>
    <p>Legality is enforced automatically in the deckbuilder. If you have a deck open, banned cards are flagged as you build.</p>
  </div>
  <hr>

  {% if activeMwl %}
    <h2>{{ activeMwl.name }}</h2>
    <p>
      <a href="{{ path('cards_find', {'q': 'b!' ~ activeMwl.code}) }}">{{ (corpCards|length) + (runnerCards|length) }} cards banned</a>.
      Active as of <strong>{{ activeMwl.dateStart|date('Y-m-d') }}</strong>.
    </p>

    <div class="container-fluid">
      <div class="row flex-fill">
        <div class="col-md-6">
          <h3>Corp Cards</h3>
          {% if corpCards is empty %}
            <p>No Corp cards are banned.</p>
          {% else %}
            <ul>
              {% for card in corpCards %}
                <li><a href="{{ path('cards_zoom', {card_code: card.code}) }}">{{ card.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
        <div class="col-md-6">
          <h3>Runner Cards</h3>
          {% if runnerCards is empty %}
            <p>No Runner cards are banned.</p>
          {% else %}
            <ul>
              {% for card in runnerCards %}
                <li><a href="{{ path('cards_zoom', {card_code: card.code}) }}">{{ card.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </div>
  {% else %}
    <p>No ban list is currently configured.</p>
  {% endif %}
</div>
{% endblock %}
